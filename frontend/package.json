{
  "name": "maas-site-manager",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "preview": "vite preview",
    "playwright-test": "playwright test",
    "playwright-ui": "playwright test --ui",
    "lint": "npmPkgJsonLint . && tsc && eslint . --ext .ts,.tsx && stylelint src/**/*.scss",
    "lint-fix": "eslint . --ext .ts,.tsx --fix && stylelint src/**/*.scss --fix",
    "upgrade-all": "yarn-upgrade-all -E"
  },
  "dependencies": {
    "@canonical/react-components": "0.44.0",
    "@sentry/browser": "5.30.0",
    "@tanstack/react-query": "4.29.25",
    "@tanstack/react-table": "8.9.3",
    "axios": "1.4.0",
    "classnames": "2.3.2",
    "date-fns": "2.30.0",
    "date-fns-tz": "2.0.0",
    "formik": "2.4.2",
    "human-interval": "2.0.1",
    "leaflet": "1.9.4",
    "lodash": "4.17.21",
    "pluralize": "8.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-error-boundary": "4.0.10",
    "react-leaflet": "4.2.1",
    "react-router-dom": "6.14.2",
    "use-local-storage-state": "18.3.3",
    "vanilla-framework": "4.0.0",
    "yup": "1.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.7.3",
    "@playwright/test": "1.36.1",
    "@remix-run/web-fetch": "4.3.5",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "14.0.0",
    "@testing-library/user-event": "14.4.3",
    "@total-typescript/ts-reset": "0.4.2",
    "@types/axios": "0.14.0",
    "@types/chance": "1.1.3",
    "@types/leaflet": "1.9.3",
    "@types/lodash": "4.14.195",
    "@types/pluralize": "0.0.30",
    "@types/react-dom": "18.2.7",
    "@types/react-leaflet": "3.0.0",
    "@typescript-eslint/parser": "6.1.0",
    "@vitejs/plugin-react-swc": "3.3.2",
    "@vitest/coverage-v8": "0.33.0",
    "abort-controller": "3.0.0",
    "autoprefixer": "10.4.14",
    "chance": "1.1.11",
    "dotenv": "16.3.1",
    "eslint": "8.45.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-config-react-app": "7.0.1",
    "eslint-import-resolver-typescript": "3.5.5",
    "eslint-plugin-cypress": "2.13.3",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-no-only-tests": "3.1.0",
    "eslint-plugin-no-relative-import-paths": "1.5.2",
    "eslint-plugin-playwright": "0.15.3",
    "eslint-plugin-prettier": "5.0.0",
    "eslint-plugin-react": "7.32.2",
    "eslint-plugin-unused-imports": "3.0.0",
    "fishery": "2.2.2",
    "happy-dom": "10.5.1",
    "i18n-iso-countries": "7.6.0",
    "jsdom": "22.1.0",
    "mockdate": "3.0.5",
    "msw": "1.2.2",
    "npm-package-json-lint": "7.0.0",
    "prettier": "3.0.0",
    "sass": "1.63.6",
    "stylelint": "15.10.1",
    "stylelint-config-standard-scss": "10.0.0",
    "timezone-mock": "1.3.6",
    "typescript": "5.0.4",
    "unique-names-generator": "4.7.1",
    "unplugin-auto-import": "0.16.6",
    "vite": "4.4.4",
    "vite-plugin-stylelint": "4.3.0",
    "vitest": "0.33.0",
    "yarn-upgrade-all": "0.7.2"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "npmpackagejsonlint": {
    "rules": {
      "prefer-absolute-version-dependencies": "error",
      "prefer-absolute-version-devDependencies": "error",
      "prefer-alphabetical-dependencies": "error",
      "prefer-alphabetical-devDependencies": "error"
    }
  },
  "yarn-upgrade-all": {
    "ignore": [
      "@sentry/browser"
    ]
  },
  "browserslist": [
    "last 1 chrome version",
    "last 1 firefox version",
    "last 1 safari version"
  ],
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  }
}
