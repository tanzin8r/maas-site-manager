{
  "name": "maas-site-manager",
  "type": "module",
  "private": true,
  "version": "1.1.0",
  "scripts": {
    "clean": "rm -rf dist node_modules",
    "predev": "yarn run download-map-assets",
    "dev": "vite",
    "prebuild": "yarn run download-map-assets",
    "download-map-assets": "chmod +x ./scripts/download-map-assets.sh && ./scripts/download-map-assets.sh",
    "build": "tsc && vite build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "cypress-open": "yarn cypress open",
    "cypress-run": "yarn cypress run",
    "generate-api-client": "openapi-ts",
    "preview": "vite preview",
    "playwright-test": "playwright test",
    "playwright-ui": "playwright test --ui",
    "lint": "npmPkgJsonLint . && tsc && eslint . && stylelint src/**/*.scss",
    "lint-fix": "npmPkgJsonLint . && tsc && eslint . --fix && stylelint src/**/*.scss --fix",
    "upgrade-all": "yarn-upgrade-all -E"
  },
  "dependencies": {
    "@canonical/maas-react-components": "2.0.0",
    "@canonical/react-components": "3.6.0",
    "@hey-api/client-axios": "0.9.1",
    "@sentry/browser": "10.23.0",
    "@tanstack/react-query": "5.90.7",
    "@tanstack/react-table": "8.21.3",
    "axios": "1.13.2",
    "classnames": "2.5.1",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "formik": "2.4.6",
    "human-interval": "2.0.1",
    "lodash": "4.17.21",
    "maplibre-gl": "5.11.0",
    "pluralize": "8.0.0",
    "pmtiles": "4.3.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "6.0.0",
    "react-router": "7.9.5",
    "react-useportal": "1.0.19",
    "use-local-storage-state": "19.5.0",
    "vanilla-framework": "4.37.0",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.0",
    "@eslint/compat": "1.4.1",
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.39.1",
    "@hey-api/openapi-ts": "0.87.1",
    "@playwright/test": "1.56.1",
    "@remix-run/web-fetch": "4.4.2",
    "@tanstack/eslint-plugin-query": "5.91.2",
    "@testing-library/cypress": "10.1.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/chance": "1.1.7",
    "@types/lodash": "4.17.20",
    "@types/pluralize": "0.0.33",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@typescript-eslint/parser": "8.46.3",
    "@vitejs/plugin-react-swc": "4.2.1",
    "@vitest/coverage-istanbul": "3.0.4",
    "abort-controller": "3.0.0",
    "autoprefixer": "10.4.21",
    "chance": "1.1.13",
    "cypress": "15.6.0",
    "cypress-axe": "1.7.0",
    "dotenv": "17.2.3",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-alias": "1.1.2",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-no-relative-import-paths": "1.6.1",
    "eslint-plugin-playwright": "2.3.0",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-testing-library": "7.13.3",
    "eslint-plugin-unused-imports": "4.3.0",
    "fishery": "2.3.1",
    "happy-dom": "20.0.10",
    "i18n-iso-countries": "7.14.0",
    "jsdom": "27.1.0",
    "jsdom-testing-mocks": "1.16.0",
    "mockdate": "3.0.5",
    "msw": "2.12.0",
    "npm-package-json-lint": "9.0.0",
    "prettier": "3.6.2",
    "sass": "1.93.3",
    "stylelint": "16.25.0",
    "stylelint-config-standard-scss": "16.0.0",
    "timezone-mock": "1.3.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.3",
    "unique-names-generator": "4.7.1",
    "unplugin-auto-import": "20.2.0",
    "vite": "7.2.2",
    "vite-plugin-stylelint": "6.0.2",
    "vitest": "3.0.4",
    "vitest-canvas-mock": "0.3.3",
    "vitest-webgl-canvas-mock": "1.1.0",
    "yarn-upgrade-all": "0.7.5"
  },
  "resolutions": {
    "strip-ansi": "^7.1.2",
    "string-width": "8.1.0"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "npmpackagejsonlint": {
    "rules": {
      "prefer-absolute-version-dependencies": "error",
      "prefer-absolute-version-devDependencies": "error",
      "prefer-alphabetical-dependencies": "error",
      "prefer-alphabetical-devDependencies": "error"
    }
  },
  "browserslist": [
    "last 1 chrome version",
    "last 1 firefox version",
    "last 1 safari version"
  ],
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  }
}
