{
  "name": "maas-site-manager",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "clean": "rm -rf dist node_modules",
    "predev": "yarn run download-map-assets",
    "dev": "vite",
    "prebuild": "yarn run download-map-assets",
    "download-map-assets": "chmod +x ./scripts/download-map-assets.sh && ./scripts/download-map-assets.sh",
    "build": "tsc && vite build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "generate-api-client-legacy": "openapi --input http://localhost:8000/api/openapi.json --output src/app/api/client --name ApiClient --exportSchemas=true --useOptions",
    "generate-api-client": "openapi-ts",
    "preview": "vite preview",
    "playwright-test": "playwright test",
    "playwright-ui": "playwright test --ui",
    "lint": "npmPkgJsonLint . && tsc && eslint . && stylelint src/**/*.scss",
    "lint-fix": "npmPkgJsonLint . && tsc && eslint . --fix && stylelint src/**/*.scss --fix",
    "upgrade-all": "yarn-upgrade-all -E"
  },
  "dependencies": {
    "@canonical/maas-react-components": "1.28.1",
    "@canonical/react-components": "2.2.0",
    "@hey-api/client-axios": "0.9.1",
    "@sentry/browser": "9.11.0",
    "@tanstack/react-query": "5.67.1",
    "@tanstack/react-table": "8.21.2",
    "axios": "1.8.4",
    "classnames": "2.5.1",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "formik": "2.4.6",
    "human-interval": "2.0.1",
    "lodash": "4.17.21",
    "maplibre-gl": "5.6.1",
    "pluralize": "8.0.0",
    "pmtiles": "4.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-error-boundary": "6.0.0",
    "react-router": "7.5.0",
    "react-useportal": "1.0.19",
    "use-local-storage-state": "19.5.0",
    "vanilla-framework": "4.13.0",
    "yup": "1.6.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.1",
    "@eslint/compat": "1.2.7",
    "@eslint/eslintrc": "3.3.0",
    "@eslint/js": "9.25.1",
    "@hey-api/openapi-ts": "0.77.0",
    "@playwright/test": "1.36.1",
    "@remix-run/web-fetch": "4.4.2",
    "@tanstack/eslint-plugin-query": "5.62.16",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/chance": "1.1.6",
    "@types/lodash": "4.17.16",
    "@types/pluralize": "0.0.33",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.2",
    "@typescript-eslint/parser": "8.29.0",
    "@vitejs/plugin-react-swc": "3.7.2",
    "@vitest/coverage-istanbul": "3.0.4",
    "abort-controller": "3.0.0",
    "autoprefixer": "10.4.20",
    "chance": "1.1.12",
    "dotenv": "16.4.7",
    "eslint": "9.27.0",
    "eslint-config-prettier": "10.1.1",
    "eslint-import-resolver-alias": "1.1.2",
    "eslint-import-resolver-typescript": "4.3.1",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-no-relative-import-paths": "1.6.1",
    "eslint-plugin-playwright": "2.2.0",
    "eslint-plugin-prettier": "5.2.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-testing-library": "7.1.1",
    "eslint-plugin-unused-imports": "4.1.4",
    "fishery": "2.2.3",
    "happy-dom": "18.0.1",
    "i18n-iso-countries": "7.14.0",
    "jsdom": "26.0.0",
    "jsdom-testing-mocks": "1.13.1",
    "mockdate": "3.0.5",
    "msw": "2.7.5",
    "npm-package-json-lint": "9.0.0",
    "openapi-typescript-codegen": "0.25.0",
    "prettier": "3.5.3",
    "sass": "1.87.0",
    "stylelint": "16.18.0",
    "stylelint-config-standard-scss": "15.0.0",
    "timezone-mock": "1.3.6",
    "typescript": "5.8.2",
    "typescript-eslint": "8.24.1",
    "unique-names-generator": "4.7.1",
    "unplugin-auto-import": "19.2.0",
    "vite": "7.0.3",
    "vite-plugin-stylelint": "6.0.0",
    "vitest": "3.1.1",
    "vitest-canvas-mock": "0.3.3",
    "vitest-webgl-canvas-mock": "1.1.0",
    "yarn-upgrade-all": "0.7.5"
  },
  "resolutions": {
    "strip-ansi": "7.1.0",
    "string-width": "7.2.0"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "npmpackagejsonlint": {
    "rules": {
      "prefer-absolute-version-dependencies": "error",
      "prefer-absolute-version-devDependencies": "error",
      "prefer-alphabetical-dependencies": "error",
      "prefer-alphabetical-devDependencies": "error"
    }
  },
  "browserslist": [
    "last 1 chrome version",
    "last 1 firefox version",
    "last 1 safari version"
  ],
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  }
}