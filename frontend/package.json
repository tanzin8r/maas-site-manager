{
  "name": "maas-site-manager",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "clean": "rm -rf dist node_modules",
    "predev": "yarn run download-map-assets",
    "dev": "vite",
    "prebuild": "yarn run download-map-assets",
    "download-map-assets": "chmod +x ./scripts/download-map-assets.sh && ./scripts/download-map-assets.sh",
    "build": "tsc && vite build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "generate-api-client": "openapi --input http://localhost:8000/api/openapi.json --output ./src/api/client --name ApiClient --exportSchemas=true --useOptions",
    "preview": "vite preview",
    "playwright-test": "playwright test",
    "playwright-ui": "playwright test --ui",
    "lint": "npmPkgJsonLint . && tsc && eslint . --ext .ts,.tsx && stylelint src/**/*.scss",
    "lint-fix": "eslint . --ext .ts,.tsx --fix && stylelint src/**/*.scss --fix",
    "upgrade-all": "yarn-upgrade-all -E"
  },
  "dependencies": {
    "@canonical/maas-react-components": "1.28.1",
    "@canonical/react-components": "0.56.0",
    "@sentry/browser": "5.30.0",
    "@tanstack/react-query": "5.64.1",
    "@tanstack/react-table": "8.20.6",
    "classnames": "2.5.1",
    "date-fns": "2.30.0",
    "date-fns-tz": "2.0.0",
    "formik": "2.4.6",
    "human-interval": "2.0.1",
    "lodash": "4.17.21",
    "maplibre-gl": "3.6.2",
    "pluralize": "8.0.0",
    "pmtiles": "2.11.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-error-boundary": "4.0.10",
    "react-router-dom": "6.22.3",
    "use-local-storage-state": "19.5.0",
    "vanilla-framework": "4.13.0",
    "yup": "1.6.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.8.1",
    "@playwright/test": "1.36.1",
    "@remix-run/web-fetch": "4.4.2",
    "@tanstack/eslint-plugin-query": "5.62.16",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "14.2.1",
    "@testing-library/user-event": "14.5.2",
    "@total-typescript/ts-reset": "0.4.2",
    "@types/chance": "1.1.6",
    "@types/lodash": "4.17.14",
    "@types/pluralize": "0.0.30",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/parser": "6.1.0",
    "@vitejs/plugin-react-swc": "3.7.2",
    "@vitest/coverage-v8": "2.1.8",
    "abort-controller": "3.0.0",
    "autoprefixer": "10.4.20",
    "chance": "1.1.12",
    "dotenv": "16.4.7",
    "eslint": "8.45.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-config-react-app": "7.0.1",
    "eslint-import-resolver-typescript": "3.7.0",
    "eslint-plugin-complexity": "1.0.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-no-relative-import-paths": "1.6.1",
    "eslint-plugin-playwright": "0.15.3",
    "eslint-plugin-prettier": "5.2.2",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-testing-library": "5.11.0",
    "eslint-plugin-unused-imports": "3.0.0",
    "fishery": "2.2.2",
    "happy-dom": "10.5.2",
    "i18n-iso-countries": "7.13.0",
    "jsdom": "24.0.0",
    "jsdom-testing-mocks": "1.13.1",
    "mockdate": "3.0.5",
    "msw": "1.2.3",
    "npm-package-json-lint": "7.0.0",
    "openapi-typescript-codegen": "0.25.0",
    "prettier": "3.4.2",
    "sass": "1.63.6",
    "stylelint": "15.10.1",
    "stylelint-config-standard-scss": "10.0.0",
    "timezone-mock": "1.3.6",
    "typescript": "5.0.4",
    "unique-names-generator": "4.7.1",
    "unplugin-auto-import": "0.16.6",
    "vite": "6.0.7",
    "vite-plugin-stylelint": "6.0.0",
    "vitest": "2.1.8",
    "vitest-canvas-mock": "0.3.3",
    "vitest-webgl-canvas-mock": "1.1.0",
    "yarn-upgrade-all": "0.7.4"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "npmpackagejsonlint": {
    "rules": {
      "prefer-absolute-version-dependencies": "error",
      "prefer-absolute-version-devDependencies": "error",
      "prefer-alphabetical-dependencies": "error",
      "prefer-alphabetical-devDependencies": "error"
    }
  },
  "yarn-upgrade-all": {
    "ignore": [
      "@sentry/browser"
    ]
  },
  "browserslist": [
    "last 1 chrome version",
    "last 1 firefox version",
    "last 1 safari version"
  ],
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  }
}